PORT=3000
APP_BASE_URL=http://localhost:3000

# Tek admin hesabı (kayıt ekranı yok)
ADMIN_EMAIL=admin@serifkuray.com
ADMIN_PASSWORD=strong_password_here

# Şifre sıfırlama maili (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="Şerif Kuray <no-reply@serifkuray.com>"
SMTP_SECURE=false

# WhatsApp Cloud API bildirimleri
# Meta'da utility template olarak 6 degiskenli bir sablon olustur:
# 1 musteri adi, 2 hizmet, 3 tarih, 4 saat, 5 usta, 6 telefon
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
WHATSAPP_NOTIFY_TO=905001234567
WHATSAPP_TEMPLATE_NAME=randevu_bildirimi
WHATSAPP_TEMPLATE_LANG=tr
WHATSAPP_API_VERSION=v18.0

# Web push bildirimleri
WEB_PUSH_ENABLED=false
WEB_PUSH_SUBJECT=mailto:admin@serifkuray.com
WEB_PUSH_PUBLIC_KEY=your_vapid_public_key
WEB_PUSH_PRIVATE_KEY=your_vapid_private_key
